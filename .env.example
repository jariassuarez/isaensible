# Path to the hosts file
HOSTS_FILE=hosts.txt

# SSH connection defaults
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_PORT=22
SSH_PASSWORD=

# Path to a known_hosts file for host key verification.
# Leave empty to skip verification (acceptable for closed networks).
SSH_KNOWN_HOSTS=

# How often the dashboard polls host status (seconds)
POLL_INTERVAL=10

# Ping settings
PING_TIMEOUT=2
PING_COUNT=1
